# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password

# Mail Configuration
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=your_email@gmail.com

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_FROM_NUMBER=+1234567890

# JWT Configuration
JWT_SECRET=your_base64_encoded_secret
JWT_EXPIRATION_MS=86400000

# Bootstrap Admin Configuration
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=Admin@123

# Service URLs
EUREKA_CLIENT_SERVICE_URL=http://localhost:8061/eureka/
EUREKA_DOCKER_SERVICE_URL=http://eureka-server:8061/eureka/
CONFIG_SERVER_URL=http://localhost:8060
CONFIG_SERVER_DOCKER_URL=http://config-server:8060

# Spring Profiles
SPRING_PROFILES_ACTIVE=local

# Database URLs
TRANSACTION_DB_URL=jdbc:postgresql://localhost:5432/transaction_db
NOTIFICATION_DB_URL=jdbc:postgresql://localhost:5432/notification_db
INTEGRATION_DB_URL=jdbc:postgresql://localhost:5432/integration_db

# CI/CD Setup: GitHub Actions workflow configured for Build and Test
EUREKA_CLIENT_SERVICE_URL=http://localhost:8061/eureka/
EUREKA_DOCKER_SERVICE_URL=http://eureka-server:8061/eureka/
CONFIG_SERVER_URL=http://localhost:8060
CONFIG_SERVER_DOCKER_URL=http://config-server:8060
# Spring Profiles
SPRING_PROFILES_ACTIVE=local
# Database URLs
TRANSACTION_DB_URL=jdbc:postgresql://localhost:5432/transaction_db
NOTIFICATION_DB_URL=jdbc:postgresql://localhost:5432/notification_db
INTEGRATION_DB_URL=jdbc:postgresql://localhost:5432/integration_db

