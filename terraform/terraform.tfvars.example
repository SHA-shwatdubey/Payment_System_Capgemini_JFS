aws_region          = "ap-south-1"
project_name        = "payment-system-capgemini"
environment         = "dev"

# EKS Configuration
node_instance_type  = "t3.large"
node_desired_size   = 2
node_min_size       = 1
node_max_size       = 4

# RDS Configuration
db_instance_class     = "db.t3.small"
db_allocated_storage  = 20
db_name               = "payment_db"
db_username           = "postgres"
db_multi_az           = false
skip_final_snapshot   = true

